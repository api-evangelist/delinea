{
  "@context": {
    "@vocab": "https://docs.delinea.com/ontology/secret-server#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "schema": "https://schema.org/",
    "delinea": "https://docs.delinea.com/ontology/secret-server#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "SecretModel": "delinea:SecretModel",
    "FolderModel": "delinea:FolderModel",
    "UserModel": "delinea:UserModel",
    "GroupModel": "delinea:GroupModel",
    "RoleModel": "delinea:RoleModel",
    "SecretPolicyModel": "delinea:SecretPolicyModel",
    "SecretTemplateModel": "delinea:SecretTemplateModel",
    "SessionRecordingModel": "delinea:SessionRecordingModel",
    "WorkflowModel": "delinea:WorkflowModel",
    "id": "@id",
    "name": "schema:name",
    "description": "schema:description",
    "createdDate": {
      "@id": "delinea:createdDate",
      "@type": "xsd:dateTime"
    },
    "modifiedDate": {
      "@id": "delinea:modifiedDate",
      "@type": "xsd:dateTime"
    },
    "active": {
      "@id": "delinea:active",
      "@type": "xsd:boolean"
    },
    "folderId": "delinea:folderId",
    "secretTemplateId": "delinea:secretTemplateId",
    "siteId": "delinea:siteId",
    "checkOutEnabled": {
      "@id": "delinea:checkOutEnabled",
      "@type": "xsd:boolean"
    },
    "accessRequestWorkflowMapId": "delinea:accessRequestWorkflowMapId",
    "lastHeartBeatStatus": "delinea:lastHeartBeatStatus",
    "requiresApproval": {
      "@id": "delinea:requiresApproval",
      "@type": "xsd:boolean"
    },
    "requiresComment": {
      "@id": "delinea:requiresComment",
      "@type": "xsd:boolean"
    },
    "secretPolicyId": "delinea:secretPolicyId",
    "username": "delinea:username",
    "emailAddress": "schema:email",
    "enabled": {
      "@id": "delinea:enabled",
      "@type": "xsd:boolean"
    },
    "displayName": "schema:name",
    "groupId": "delinea:groupId",
    "roleId": "delinea:roleId",
    "permissions": "delinea:permissions",
    "tags": "schema:keywords"
  }
}